# homeclaw configuration
# Copy to .env and fill in your values.

# LLM provider — set one:
ANTHROPIC_API_KEY=
# or use OpenAI-compatible (e.g. OpenRouter):
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Default model (used when routing is not configured)
MODEL=claude-sonnet-4-6

# Model routing — override per call type:
# CONVERSATION_MODEL=anthropic/claude-sonnet-4-6
# ROUTINE_MODEL=anthropic/claude-haiku-4-5-20251001

# Output token limits:
# MAX_OUTPUT_TOKENS=1024
# ROUTINE_MAX_OUTPUT_TOKENS=512

# Prompt caching (Anthropic only):
# ENABLE_PROMPT_CACHING=true

# Batch routines (Anthropic only, 50% token discount):
# ENABLE_BATCH_ROUTINES=true

# Telegram bot:
# TELEGRAM_TOKEN=

# Home Assistant integration:
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=

# Web UI:
# WEB_PORT=8080
# WEB_PASSWORD=

# Workspaces path:
# WORKSPACES_PATH=./workspaces

# Semantic memory (requires memsearch extra):
# ENHANCED_MEMORY=false

# Context budget:
# MAX_FACTS_PER_PERSON=20
# MAX_CONTACTS_IN_CONTEXT=5
# MAX_SEMANTIC_CHUNKS=3
# MAX_HA_ENTITIES=20
